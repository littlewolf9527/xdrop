# Phase 2 live-test matrix env template.
# Copy to phase2-lt-matrix.env (gitignored) and adjust for your lab, then:
#   source scripts/phase2-lt-matrix.env
#   python3 scripts/phase2-lt-matrix.py
#
# The Python driver refuses to start with any required var unset.

# ---- required ---------------------------------------------------------------

# SSH user@host for the xdrop gateway (runs the node agent + controller).
# Must have pubkey auth; the harness opens many short connections.
export PHASE2_GATEWAY=root@<gateway-host>

# SSH user@host for Host B, the traffic driver. Needs hping3 + ping.
export PHASE2_HOSTB=root@<host-b>

# IPv4 of the gateway's XDP-facing NIC. Traffic is sent TO this address.
export PHASE2_DST_GW=<gateway-lab-nic-ipv4>

# IPv4 of Host B's NIC that emits traffic. Used as src for LT-M combos and
# as the target of src_ip / src_cidr fixture rules.
export PHASE2_SRC_HB=<host-b-lab-nic-ipv4>

# L2 subnet that covers SRC_HB (and the rule-D CIDR in the LT-C2b coexistence
# test). Must be exactly the subnet both endpoints share.
export PHASE2_LAB_SUBNET=<cidr-covering-SRC_HB>   # e.g., 10.0.0.0/24

# ---- optional (sensible defaults) ------------------------------------------

# Controller + node API endpoints. Defaults assume harness runs locally on
# the gateway via SSH, so localhost:{8000,8080} are correct for the
# `curl` that SSH executes remotely.
export PHASE2_CTRL_URL=http://localhost:8000
export PHASE2_NODE_URL=http://localhost:8080

# API keys. Defaults match the `*-change-me` placeholders in
# {controller,node}/config.example.yaml. Override when running against a
# deployment that uses real rotated keys.
export PHASE2_CTRL_KEY=xdrop-external-key-change-me
export PHASE2_NODE_KEY=node-secret-key-change-me
